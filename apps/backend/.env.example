DATABASE_URL='postgresql://postgres:postgres@localhost:5433/wealth-db'
DATABASE_PASSWORD='postgres'
DATABASE_NAME='wealth-db'
JWT_SECRET='secret'

# Comma-separated browser origins allowed to call the API (oRPC + REST). Omit for dev (reflect request Origin).
# CORS_ORIGIN=http://localhost:5173

# Sentry: only when NODE_ENV is `production` or `staging` and SENTRY_DSN is set.
SENTRY_DSN=
