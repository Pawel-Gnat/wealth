{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"extends": ["@repo/biome-config/biome"],
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"root": "../.."
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"overrides": [
		{
			"includes": [
				"src/**/*.controller.ts",
				"src/**/*.module.ts",
				"src/**/*.service.ts",
				"src/**/*.strategy.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"useImportType": "off"
					}
				}
			}
		}
	]
}
