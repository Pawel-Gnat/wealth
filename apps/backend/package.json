{
	"name": "backend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "nest build",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome check --write .",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "biome check .",
		"db:generate": "drizzle-kit generate --config src/drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config src/drizzle.config.ts",
		"db:show": "drizzle-kit studio --config src/drizzle.config.ts",
		"db:push": "drizzle-kit push --config src/drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config src/drizzle.config.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"start:e2e": "tsx src/test/start-e2e.ts"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.0.1",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@orpc/nest": "^1.14.0",
		"@orpc/openapi": "^1.14.0",
		"@orpc/server": "^1.14.0",
		"@orpc/zod": "^1.14.0",
		"@repo/api": "workspace:*",
		"@repo/common": "workspace:*",
		"@sentry/nestjs": "^9.47.1",
		"@sentry/profiling-node": "^9.47.1",
		"bcrypt": "^6.0.0",
		"drizzle-orm": "^0.45.2",
		"passport-jwt": "^4.0.1",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-ui-express": "^5.0.1",
		"ulid": "^3.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@repo/biome-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@swc/core": "^1.10.18",
		"@testcontainers/postgresql": "^11.14.0",
		"@types/bcrypt": "^6.0.0",
		"@types/express": "^5.0.0",
		"@types/node": "^22.10.7",
		"@types/passport-jwt": "^4.0.1",
		"@types/pg": "^8.20.0",
		"@types/swagger-ui-express": "^4.1.8",
		"@vitest/coverage-v8": "^3.2.4",
		"drizzle-kit": "^0.31.10",
		"source-map-support": "^0.5.21",
		"testcontainers": "^11.14.0",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "catalog:",
		"unplugin-swc": "^1.5.1",
		"vitest": "catalog:"
	}
}
