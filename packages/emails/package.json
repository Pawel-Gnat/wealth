		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@react-email/ui": "6.0.0",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:"
	},
	"dependencies": {
		"@biomejs/biome": "catalog:",
		"@repo/biome-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"typescript": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-email": "6.0.0"
	}
}
