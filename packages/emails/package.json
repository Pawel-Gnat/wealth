{
	"name": "@repo/emails",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"preview": "email dev --dir src/emails --port 8000",
