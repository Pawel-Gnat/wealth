{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["ES2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolvePackageJsonExports": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": "./src",
		"outDir": "./dist"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
