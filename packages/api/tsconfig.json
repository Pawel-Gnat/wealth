{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/schemas/*": ["./schemas/*"],
			"@/contracts/*": ["./contracts/*"]
		}
	},
	"include": ["schemas", "contracts"]
}
