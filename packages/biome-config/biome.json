{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"root": false,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**",
			"!**/build/**",
			"!**/out/**",
			"!**/coverage/**",
			"!**/src/shared/lib/ui/**"
		],
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 80
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"json": {
		"formatter": {
			"enabled": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
